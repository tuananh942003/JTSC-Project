{
  "name": "var-project",
  "version": "1.0.0",
  "description": "VAR - Visionary AI & Robotics",
  "private": true,
  "scripts": {
    "build": "npm run build:fe",
    "build:fe": "cd \"FE/vite-project\" && npm install && npm run build",
    "install:all": "npm run install:fe && npm run install:server && npm run install:chatbot",
    "install:fe": "cd \"FE/vite-project\" && npm install",
    "install:server": "cd server && npm install",
    "install:chatbot": "cd \"AI Chatbot\" && npm install",
    "start": "pm2 start ecosystem.config.cjs",
    "stop": "pm2 stop ecosystem.config.cjs",
    "restart": "pm2 restart ecosystem.config.cjs",
    "reload": "pm2 reload ecosystem.config.cjs",
    "logs": "pm2 logs",
    "status": "pm2 status",
    "dev": "powershell -ExecutionPolicy Bypass -File .\\start.ps1"
  }
}
