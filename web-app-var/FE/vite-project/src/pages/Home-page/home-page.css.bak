/* ============================================================
   HOME PAGE  — Modern editorial layout with animations
   ============================================================ */

/* ===== Hero Section ===== */
.home-page {
    background:
        linear-gradient(135deg, rgba(30,27,75,.88) 0%, rgba(49,46,129,.80) 50%, rgba(76,29,149,.82) 100%),
        url("../../images/computerscience-scaled.jpg");
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    background-attachment: fixed;
    min-height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    gap: 80px;
    position: relative;
    overflow: hidden;
    padding: 80px 5%;
}

/* Animated gradient orbs */
.home-page::before {
    content: '';
    position: absolute;
    width: 600px; height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(99,102,241,.25) 0%, transparent 70%);
    top: -150px; right: -100px;
    animation: orbFloat 8s ease-in-out infinite;
    pointer-events: none;
}
.home-page::after {
    content: '';
    position: absolute;
    width: 400px; height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(167,139,250,.20) 0%, transparent 70%);
    bottom: -100px; left: 10%;
    animation: orbFloat 10s ease-in-out infinite reverse;
    pointer-events: none;
}

@keyframes orbFloat {
    0%, 100% { transform: translateY(0) scale(1); }
    50%       { transform: translateY(-30px) scale(1.06); }
}

/* Floating grid dots decoration */
.hero-dots {
    position: absolute;
    inset: 0;
    background-image:
        radial-gradient(circle, rgba(255,255,255,.09) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
}

.left-home-page {
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: #fff;
    width: 52%;
    position: relative;
    z-index: 1;
    animation: heroFadeLeft 0.9s cubic-bezier(0.4,0,0.2,1) forwards;
}

@keyframes heroFadeLeft {
    from { opacity: 0; transform: translateX(-48px); }
    to   { opacity: 1; transform: none; }
}

/* Hero badge */
.hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.2);
    backdrop-filter: blur(12px);
    padding: 7px 16px;
    border-radius: 99px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: rgba(255,255,255,.9);
    margin-bottom: 24px;
    width: fit-content;
}
.hero-badge span {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #34d399;
    animation: pulse 2s ease-in-out infinite;
    flex-shrink: 0;
}
@keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(52,211,153,.5); }
    50%       { box-shadow: 0 0 0 6px rgba(52,211,153,0); }
}

.left-home-page h1 {
    font-size: clamp(32px, 4.5vw, 56px);
    margin-bottom: 20px;
    font-family: "Montserrat", sans-serif;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    text-shadow: 0 4px 24px rgba(0,0,0,.25);
}
.left-home-page h1 .highlight {
    background: linear-gradient(135deg, #a5b4fc, #e879f9);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.left-home-page p {
    font-size: 18px;
    margin-bottom: 10px;
    font-family: "Montserrat", sans-serif;
    font-weight: 400;
    line-height: 1.7;
    color: rgba(255,255,255,.80);
}

.home-page-action {
    display: flex;
    gap: 14px;
    margin-top: 36px;
    flex-wrap: wrap;
}

.home-page-action a { text-decoration: none; }

.home-page .home-page-action button {
    padding: 14px 36px;
    font-size: 15.5px;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    font-weight: 700;
    font-family: "Montserrat", sans-serif;
    transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
    position: relative;
    overflow: hidden;
    letter-spacing: 0.01em;
}
.home-page .home-page-action button::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,.15);
    opacity: 0;
    transition: opacity 0.25s;
}
.home-page .home-page-action button:hover::after { opacity: 1; }

.home-page .home-page-action button:first-child {
    background: #ffffff;
    color: #4f46e5;
    box-shadow: 0 8px 28px rgba(0,0,0,.22);
}
.home-page .home-page-action button:first-child:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 40px rgba(0,0,0,.3);
}
.home-page .home-page-action button:last-child {
    background: rgba(255,255,255,.1);
    color: #fff;
    border: 1.5px solid rgba(255,255,255,.45);
    backdrop-filter: blur(8px);
}
.home-page .home-page-action button:last-child:hover {
    background: rgba(255,255,255,.18);
    border-color: rgba(255,255,255,.75);
    transform: translateY(-3px);
}

/* Hero stats strip */
.hero-stats {
    display: flex;
    gap: 32px;
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid rgba(255,255,255,.15);
}
.hero-stat-item { display: flex; flex-direction: column; gap: 2px; }
.hero-stat-num {
    font-family: "Montserrat", sans-serif;
    font-size: 26px;
    font-weight: 800;
    color: #fff;
    line-height: 1;
}
.hero-stat-lbl {
    font-size: 12px;
    color: rgba(255,255,255,.55);
    font-family: "Montserrat", sans-serif;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
}

/* Right hero image */
.right-home-page {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    animation: heroFadeRight 0.9s cubic-bezier(0.4,0,0.2,1) forwards;
}
@keyframes heroFadeRight {
    from { opacity: 0; transform: translateX(48px); }
    to   { opacity: 1; transform: none; }
}

.right-home-page img {
    width: min(480px, 90%);
    filter: drop-shadow(0 24px 48px rgba(0,0,0,.35));
    transition: transform 0.4s ease;
}
.right-home-page img:hover { transform: scale(1.04) translateY(-6px); }

/* ===== Section: About / Features ===== */
.subtitle {
    text-align: center;
    padding: 80px 20px 32px;
}
.subtitle h2 {
    font-family: "Montserrat", sans-serif;
    font-weight: 800;
    font-size: clamp(26px, 4vw, 42px);
    color: #0f172a;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
}
.subtitle h2 span {
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}
.subtitle p {
    font-family: "Montserrat", sans-serif;
    font-size: 17px;
    color: #64748b;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
}

.about-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin: 40px 80px;
}

.about-text {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 28px;
}

/* Feature cards */
.feature-item {
    padding: 32px 28px;
    margin-bottom: 0;
    display: flex;
    gap: 20px;
    background: #ffffff;
    border-radius: 18px;
    border: 1px solid #e2e8f0;
    align-items: flex-start;
    transition: transform 0.32s cubic-bezier(0.4,0,0.2,1), box-shadow 0.32s ease, border-color 0.32s ease;
    box-shadow: 0 2px 12px rgba(15,23,42,.05);
    position: relative;
    overflow: hidden;
}
.feature-item::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 3px;
    background: linear-gradient(90deg, #4f46e5, #7c3aed);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s ease;
}
.feature-item:hover::before { transform: scaleX(1); }
.feature-item:hover {
    transform: translateY(-8px);
    box-shadow: 0 16px 48px rgba(79,70,229,.13);
    border-color: rgba(79,70,229,.2);
}

.info-title {
    font-family: "Montserrat", sans-serif;
    font-weight: 700;
    font-size: 20px;
    color: #0f172a;
    margin: 0 0 8px;
}
.info-description {
    font-family: "Montserrat", sans-serif;
    font-size: 15px;
    line-height: 1.7;
    color: #64748b;
    margin: 0;
}

/* Stat cards */
.about-stat {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 40px;
}
.home-stat-card {
    background: #ffffff;
    border-radius: 18px;
    border: 1px solid #e2e8f0;
    padding: 32px 20px;
    text-align: center;
    box-shadow: 0 2px 12px rgba(15,23,42,.05);
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.home-stat-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 100%; height: 3px;
    background: linear-gradient(90deg, #4f46e5, #7c3aed);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.35s ease;
}
.home-stat-card:hover::after { transform: scaleX(1); }
.home-stat-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 14px 44px rgba(79,70,229,.12);
}
.stat-number {
    font-family: "Montserrat", sans-serif;
    font-weight: 800;
    font-size: 42px;
    margin-bottom: 8px;
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
}
.stat-label {
    font-family: "Montserrat", sans-serif;
    font-weight: 600;
    font-size: 14px;
    color: #64748b;
    letter-spacing: 0.02em;
}

/* ===== Service section ===== */
.service-header-home {
    text-align: center;
    margin-top: 80px;
    padding: 0 20px;
}
.service-header-home h4 {
    font-family: "Montserrat", sans-serif;
    font-weight: 800;
    font-size: clamp(26px, 4vw, 42px);
    color: #0f172a;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
}
.service-header-home h4 span {
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}
.service-header-home p {
    font-family: "Montserrat", sans-serif;
    font-size: 17px;
    color: #64748b;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
}

.card-wrapper-service {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 28px;
    margin: 48px 80px;
}

.feature-item-service {
    padding: 32px 28px;
    margin-bottom: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    background: #ffffff;
    border-radius: 18px;
    border: 1px solid #e2e8f0;
    align-items: flex-start;
    text-align: left;
    box-shadow: 0 2px 12px rgba(15,23,42,.05);
    position: relative;
    overflow: hidden;
    transition: transform 0.32s ease, box-shadow 0.32s ease, border-color 0.32s ease;
}
.feature-item-service::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 4px; height: 100%;
    background: linear-gradient(180deg, #4f46e5, #7c3aed);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.35s ease;
}
.feature-item-service:hover::before { transform: scaleY(1); }
.feature-item-service:hover {
    transform: translateY(-8px);
    box-shadow: 0 16px 48px rgba(79,70,229,.12);
    border-color: rgba(79,70,229,.2);
}
.feature-item-service-info h3 {
    font-family: "Montserrat", sans-serif;
    font-weight: 700;
    font-size: 18px;
    color: #0f172a;
    margin: 0 0 8px;
}
.feature-item-service-info p {
    font-family: "Montserrat", sans-serif;
    font-size: 14.5px;
    color: #64748b;
    line-height: 1.7;
    margin: 0;
}

/* ===== News section ===== */
.news-header {
    text-align: center;
    margin-top: 80px;
    padding: 0 20px;
}
.news-header h5 {
    font-family: "Montserrat", sans-serif;
    font-weight: 800;
    font-size: clamp(26px, 4vw, 42px);
    color: #0f172a;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
}
.news-header h5 span {
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}
.news-header p {
    font-family: "Montserrat", sans-serif;
    font-size: 17px;
    color: #64748b;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
}

.card-wrapper-news {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 28px;
    margin: 48px 80px 80px;
}
.container-news { width: 100%; }

.feature-item-news {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border-radius: 18px;
    border: 1px solid #e2e8f0;
    overflow: hidden;
    transition: transform 0.32s ease, box-shadow 0.32s ease;
    box-shadow: 0 2px 12px rgba(15,23,42,.05);
    cursor: pointer;
}
.feature-item-news:hover {
    transform: translateY(-8px);
    box-shadow: 0 16px 48px rgba(79,70,229,.12);
}

.news-image {
    width: 100%;
    overflow: hidden;
    position: relative;
}
.news-image img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    transition: transform 0.45s ease;
    display: block;
}
.feature-item-news:hover .news-image img { transform: scale(1.07); }

/* Category tag on image */
.news-image::after {
    content: attr(data-cat);
    position: absolute;
    top: 12px; left: 12px;
    background: rgba(79,70,229,.85);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 6px;
    backdrop-filter: blur(4px);
}

.news-info { padding: 20px 22px 24px; }

.feature-item-news-info-title {
    font-family: "Montserrat", sans-serif;
    font-weight: 700;
    font-size: 16.5px;
    color: #0f172a;
    line-height: 1.45;
    margin: 0 0 10px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.feature-item-news-info-description {
    font-family: "Montserrat", sans-serif;
    font-size: 13.5px;
    color: #64748b;
    line-height: 1.65;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.news-extension {
    display: flex;
    gap: 14px;
    align-items: center;
    margin-top: 14px;
    font-size: 12.5px;
    color: #94a3b8;
    font-family: "Montserrat", sans-serif;
    font-weight: 500;
}
.news-extension i { color: #a5b4fc; }

/* ===== RESPONSIVE ===== */
@media (max-width: 1024px) {
    .home-page { gap: 50px; padding: 60px 4%; }
    .left-home-page h1 { font-size: 36px; }
    .about-content, .card-wrapper-service, .card-wrapper-news { margin-left: 40px; margin-right: 40px; }
    .about-stat { grid-template-columns: repeat(2, 1fr); }
    .hero-stats { gap: 22px; }
}

@media (max-width: 768px) {
    .home-page {
        flex-direction: column;
        gap: 40px;
        padding: 80px 20px 60px;
        background-attachment: scroll;
        min-height: 100vh;
    }
    .left-home-page { width: 100%; text-align: center; }
    .hero-badge { margin: 0 auto 24px; }
    .home-page-action { flex-direction: column; align-items: stretch; margin-top: 28px; }
    .home-page .home-page-action button { width: 100%; }
    .hero-stats { justify-content: center; flex-wrap: wrap; gap: 20px; }
    .right-home-page { width: 100%; }
    .right-home-page img { max-width: 320px; }
    .about-content { margin: 20px 20px; }
    .about-text { grid-template-columns: 1fr; }
    .about-stat { grid-template-columns: 1fr 1fr; gap: 16px; }
    .card-wrapper-service, .card-wrapper-news { margin: 40px 20px; }
}

@media (max-width: 480px) {
    .left-home-page h1 { font-size: 28px; }
    .left-home-page p { font-size: 16px; }
    .about-stat { grid-template-columns: 1fr; }
    .stat-number { font-size: 36px; }
}
